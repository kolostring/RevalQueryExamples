@using CachingDemo.Client.Services
@page "/search-bar"
@attribute [StreamRendering]
@rendermode InteractiveWebAssembly
@implements IDisposable

<PageTitle>Search Bar Example</PageTitle>

<div class="search-box">
    <div class="d-flex">
        <input @bind="SearchTerm" @bind:event="oninput" placeholder="Type to search..."/>

        @if (IsLoading)
        {
            <div class="spinner-border spinner-border-sm">
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <p style="color:red">Error: @ErrorMessage</p>
    }
    else @if (Suggestions.Any())
    {
        <ul>
            @foreach (var item in Suggestions)
            {
                <li>@item</li>
            }
        </ul>
    }
    else if (IsLoading)
    {
        <p><em>Nothing to show</em></p>
    }
</div>

@code {
    private List<string> Suggestions { get; set; } = new();
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    private CancellationTokenSource? _runningCts;

    private string SearchTerm
    {
        get;
        set
        {
            if (field == value) return;
            field = value;
            _ = ExecuteSearch(field);
        }
    } = string.Empty;

    protected override void OnInitialized()
    {
        _ = ExecuteSearch("");
    }

    private async Task ExecuteSearch(string term)
    {
        if (_runningCts is not null)
        {
            await _runningCts.CancelAsync();
            _runningCts.Dispose();
        }
        
        var currentCts = new CancellationTokenSource();
        _runningCts = currentCts;

        ErrorMessage = null;

        IsLoading = true;
        try
        {
            Suggestions = await SearchService.SearchAsync(term, _runningCts.Token);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (!currentCts.Token.IsCancellationRequested)
            {
                IsLoading = false;
                // Or will get stuck
                StateHasChanged();
            }
        }
    }

    public void Dispose() => _runningCts?.Dispose();
}